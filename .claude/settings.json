{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx tsc *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(ls *)",
      "Bash(cat ~/.claude/*)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq * ~/.claude/*)",
      "Bash(mkdir -p src/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/zm-block-claude-dir-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/zm-block-dangerous-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/zm-lint-on-save.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "이 세션에서 방금 완료된 작업을 기반으로, 프로젝트 문서 갱신이 필요한지 판단하라. 다음을 확인: (1) roadmap 체크리스트 항목이 완료되었는가? (2) 새로운 이슈가 발견되었는가? (3) 정책이나 PRD가 변경되었는가? (4) 새 아이디어가 언급되었는가? 갱신이 필요하면 {\"ok\": false, \"reason\": \"갱신 필요: [구체적 문서명과 갱신 내용]\"} 반환. 갱신 불필요하면 {\"ok\": true} 반환."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code가 입력을 기다리고 있습니다\" with title \"zm-agent-manager\"'"
          }
        ]
      }
    ]
  }
}
